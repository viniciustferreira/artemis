<!DOCTYPE html>
<html>
  <head>
    <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #0a0e17;
        font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;
        color: #e2e8f0;
      }
      table {
        border-spacing: 0;
        border-collapse: collapse;
      }
      .wrapper {
        width: 100%;
        background-color: #0a0e17;
        background-image: radial-gradient(circle at 10% 20%, rgba(99, 102, 241, 0.18) 0, rgba(99, 102, 241, 0) 40%), radial-gradient(circle at 90% 10%, rgba(251, 191, 36, 0.16) 0, rgba(251, 191, 36, 0) 35%);
      }
      .container {
        width: 100%;
        max-width: 640px;
        margin: 0 auto;
        background-color: #111827;
        border: 1px solid #263247;
        border-radius: 14px;
        overflow: hidden;
      }
      .header {
        background-color: #1e1b4b;
        background-image: linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #0f172a 100%);
        text-align: center;
        padding: 28px 24px;
      }
      .title {
        margin: 0;
        font-size: 28px;
        line-height: 1.2;
        color: #f8fafc;
        font-weight: 700;
      }
      .subtitle {
        margin: 8px 0 0;
        color: #cbd5e1;
        font-size: 14px;
      }
      .content {
        padding: 24px;
      }
      .greeting {
        margin: 0 0 10px;
        font-size: 20px;
        color: #f8fafc;
      }
      .muted {
        margin: 0 0 18px;
        color: #94a3b8;
        font-size: 14px;
      }
      .panel {
        background-color: #0f172a;
        border: 1px solid #1f2937;
        border-radius: 10px;
      }
      .phase-icon {
        font-size: 56px;
        line-height: 1;
      }
      .phase-name {
        margin-top: 8px;
        color: #fbbf24;
        font-size: 28px;
        font-weight: 700;
      }
      .label {
        color: #94a3b8;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.8px;
      }
      .value {
        margin-top: 6px;
        color: #e2e8f0;
        font-size: 18px;
        font-weight: 700;
      }
      .badge-purple {
        display: inline-block;
        padding: 6px 10px;
        border-radius: 999px;
        background: #312e81;
        border: 1px solid #4f46e5;
        color: #c7d2fe;
        font-size: 12px;
        font-weight: 600;
      }
      .badge-gold {
        display: inline-block;
        padding: 6px 10px;
        border-radius: 999px;
        background: #78350f;
        border: 1px solid #f59e0b;
        color: #fde68a;
        font-size: 12px;
        font-weight: 600;
      }
      .days-card {
        background: #0f172a;
        border: 1px solid #1f2937;
        border-radius: 10px;
        padding: 14px;
      }
      .days-number {
        font-size: 32px;
        font-weight: 700;
        color: #f8fafc;
      }
      .days-number.gold {
        color: #fbbf24;
      }
      .days-number.indigo {
        color: #a5b4fc;
      }
      .days-label {
        color: #94a3b8;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        margin-top: 4px;
      }
      .progress-track {
        margin-top: 10px;
        height: 8px;
        border-radius: 99px;
        background: #1f2937;
        overflow: hidden;
      }
      .progress-fill {
        height: 8px;
        border-radius: 99px;
        background: linear-gradient(90deg, #6366f1 0%, #3b82f6 100%);
      }
      .footer {
        border-top: 1px solid #1f2937;
        padding: 18px 24px;
        text-align: center;
        color: #64748b;
        font-size: 12px;
      }
      @media (max-width: 600px) {
        .container {
          border-radius: 0;
        }
        .content {
          padding: 18px;
        }
        .title {
          font-size: 24px;
        }
      }
    </style>
  </head>
  <body>
    <% full_days = (@moon_data.days_until_full_moon || 0).to_i %>
    <% new_days = (@moon_data.days_until_new_moon || 0).to_i %>
    <% full_progress = [[(full_days.fdiv(29.53) * 100).round, 100].min, 0].max %>
    <% new_progress = [[(new_days.fdiv(29.53) * 100).round, 100].min, 0].max %>
    <% phase_icon = case @moon_data.phase.to_s.downcase
                   when /nova/
                     '🌑'
                   when /cheia/
                     '🌕'
                   when /minguante/
                     '🌗'
                   when /crescente/
                     '🌓'
                   else
                     '🌙'
                   end %>

    <div style="display:none;max-height:0;overflow:hidden;mso-hide:all;font-size:1px;line-height:1px;color:#0a0e17;">Seu boletim lunar diário: fase atual, signo e dias para os próximos eventos lunares.</div>

    <table role="presentation" width="100%" class="wrapper">
      <tr>
        <td align="center" style="padding: 24px 12px;">
          <table role="presentation" width="100%" class="container">
            <tr>
              <td class="header">
                <div style="font-size: 38px; line-height: 1;">🌙</div>
                <h1 class="title">Boletim Lunar Diário</h1>
                <p class="subtitle">Artemis • Informações da lua para hoje</p>
              </td>
            </tr>

            <tr>
              <td class="content">
                <p class="greeting">Olá, <strong><%= @user.name || 'amigo' %></strong>!</p>
                <p class="muted">Aqui está o resumo lunar com o mesmo estilo cósmico da página do app.</p>

                <table role="presentation" width="100%" class="panel" style="text-align:center; margin-bottom: 16px;">
                  <tr>
                    <td style="padding: 18px 14px;">
                      <div class="phase-icon"><%= phase_icon %></div>
                      <div class="phase-name"><%= @moon_data.phase || 'Sem fase' %></div>
                    </td>
                  </tr>
                </table>

                <table role="presentation" width="100%" class="panel" style="margin-bottom: 16px;">
                  <tr>
                    <td style="padding: 14px; border-bottom: 1px solid #1f2937;">
                      <div class="label">Signo</div>
                      <div style="margin-top: 6px;"><span class="badge-purple"><%= @moon_data.sign || 'N/D' %></span></div>
                    </td>
                  </tr>
                  <tr>
                    <td style="padding: 14px;">
                      <div class="label">Título da lua</div>
                      <div style="margin-top: 6px;"><span class="badge-gold"><%= @moon_data.special_moon || 'Nenhuma lua especial' %></span></div>
                    </td>
                  </tr>
                </table>

                <table role="presentation" width="100%">
                  <tr>
                    <td width="50%" style="padding-right: 6px; vertical-align: top;">
                      <table role="presentation" width="100%" class="days-card">
                        <tr><td class="days-number gold"><%= full_days %></td></tr>
                        <tr><td class="days-label">dias até a lua cheia</td></tr>
                        <tr>
                          <td>
                            <div class="progress-track">
                              <div class="progress-fill" style="width: <%= full_progress %>%;"></div>
                            </div>
                          </td>
                        </tr>
                      </table>
                    </td>

                    <td width="50%" style="padding-left: 6px; vertical-align: top;">
                      <table role="presentation" width="100%" class="days-card">
                        <tr><td class="days-number indigo"><%= new_days %></td></tr>
                        <tr><td class="days-label">dias até a lua nova</td></tr>
                        <tr>
                          <td>
                            <div class="progress-track">
                              <div class="progress-fill" style="width: <%= new_progress %>%;"></div>
                            </div>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td class="footer">
                © <%= Time.current.year %> Artemis Lunar Daily • Feito para suas atualizações lunares.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>