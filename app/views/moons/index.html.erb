<div class="container">
  <!-- Stars Background -->
  <div class="stars">
    <% 50.times do |i| %>
      <div class="star" style="
        left: <%= rand * 100 %>%;
        top: <%= rand * 100 %>%;
        animation-delay: <%= rand * 2 %>s;
        animation-duration: <%= 1.5 + rand * 2 %>s;
      "></div>
    <% end %>
  </div>
   <% if @last_checked_moon %>
   <% phase_key = @last_checked_moon.dig(:api_response, :phase, :name).to_s.downcase.tr(" ", "_") %>
    <% phase_css = phase_key.present? ? phase_key.tr("_", "-") : "full-moon" %>
    <% full_days = (@last_checked_moon[:days_until_full_moon] || 0).to_i %>
    <% new_days = (@last_checked_moon[:days_until_new_moon] || 0).to_i %>
    <% full_progress = [[full_days.fdiv(29.53) * 100, 100].min, 0].max %>
    <% new_progress = [[new_days.fdiv(29.53) * 100, 100].min, 0].max %>

    <!-- Header -->
    <header class="app-header">
      <h1>🌙 Artemis</h1>
      <p>Informações sobre a Fase Atual da Lua</p>
    </header>

    <!-- Card Lua -->
    <div class="moon-card phase-<%= phase_css %>">
      <!-- Lua  -->
      <div class="moon-visual moon-<%= phase_css %>"></div>

      <!-- Grid Lua -->
      <div class="moon-data-grid">
        <!-- Fase da Lua -->
        <div class="data-item">
          <div class="data-item-label">Fase atual</div>
          <div class="data-item-value highlight">
            <%= @last_checked_moon[:phase]&.humanize || 'Unknown' %>
          </div>
        </div>

        <!-- Signo -->
        <div class="data-item">
          <div class="data-item-label">Signo</div>
          <div class="data-item-value">
            <span class="badge badge-purple">
              <%= @last_checked_moon[:sign]&.humanize || 'Unknown' %>
            </span>
          </div>
        </div>

        <!-- Nome da Lua -->
        <div class="data-item">
          <div class="data-item-label">Título da Lua</div>
          <div class="data-item-value">
            <span class="badge badge-gold">
              <%= @last_checked_moon[:special_moon]&.humanize || 'Regular Moon' %>
            </span>
          </div>
        </div>

        <!-- Days Until Full Moon -->
        <div class="data-item">
          <div class="data-item-label">Dias até a Lua Cheia</div>
          <div class="data-item-value">
            <%= @last_checked_moon[:days_until_full_moon] || 0 %> dias
          </div>
          <div class="progress-container">
            <div class="progress-bar">
              <div class="progress-fill" style="width: <%= full_progress %>%;"></div>
            </div>
            </div>
        </div>

        <!-- Days Until New Moon -->
        <div class="data-item">
          <div class="data-item-label">Dias até a Lua Nova</div>
          <div class="data-item-value">
            <%= @last_checked_moon[:days_until_new_moon] || 0 %> dias
          </div>
          <div class="progress-container">
            <div class="progress-bar">
              <div class="progress-fill" style="width: <%= new_progress %>%;"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

  <% else %>
    <p>Nenhuma informação disponível sobre a lua.</p>
    <div class="moon-card">
      <p style="text-align: center; color: var(--moon-text-muted);">Não há dados disponíveis para exibir.</p>
    </div>
  <% end %>
</div>
