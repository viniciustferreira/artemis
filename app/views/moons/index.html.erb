<div class="container">
  <!-- Stars Background -->
  <div class="stars">
    <% 50.times do |i| %>
      <div class="star" style="
        left: <%= rand * 100 %>%;
        top: <%= rand * 100 %>%;
        animation-delay: <%= rand * 2 %>s;
        animation-duration: <%= 1.5 + rand * 2 %>s;
      "></div>
    <% end %>
  </div>

  <% if @last_checked_moon %>
    <!-- Header -->
    <header class="app-header">
      <h1>🌙 Artemis</h1>
      <p>Current Moon Phase Information</p>
    </header>

    <!-- Moon Card -->
    <div class="moon-card phase-<%= @last_checked_moon[:phase]&.parameterize || 'full' %>">
      <!-- Moon Visual -->
      <div class="moon-visual"></div>

      <!-- Moon Data Grid -->
      <div class="moon-data-grid">
        <!-- Moon Phase -->
        <div class="data-item">
          <div class="data-item-label">Current Phase</div>
          <div class="data-item-value highlight">
            <%= @last_checked_moon[:phase]&.humanize || 'Unknown' %>
          </div>
        </div>

        <!-- Zodiac Sign -->
        <div class="data-item">
          <div class="data-item-label">Zodiac Sign</div>
          <div class="data-item-value">
            <span class="badge badge-purple">
              <%= @last_checked_moon[:sign]&.humanize || 'Unknown' %>
            </span>
          </div>
        </div>

        <!-- Special Moon Title -->
        <div class="data-item">
          <div class="data-item-label">Moon Name</div>
          <div class="data-item-value">
            <span class="badge badge-gold">
              <%= @last_checked_moon[:special_moon]&.humanize || 'Regular Moon' %>
            </span>
          </div>
        </div>

        <!-- Days Until Full Moon -->
        <div class="data-item">
          <div class="data-item-label">Days Until Full Moon</div>
          <div class="data-item-value">
            <%= @last_checked_moon[:days_until_full_moon] || 0 %> days
          </div>
          <div class="progress-container">
            <div class="progress-bar">
              <div class="progress-fill" style="width: <%= ((@last_checked_moon[:days_until_full_moon] || 0) / 14.0) * 100 %>%;"></div>
            </div>
          </div>
        </div>

        <!-- Days Until New Moon -->
        <div class="data-item">
          <div class="data-item-label">Days Until New Moon</div>
          <div class="data-item-value">
            <%= @last_checked_moon[:days_until_new_moon] || 0 %> days
          </div>
          <div class="progress-container">
            <div class="progress-bar">
              <div class="progress-fill" style="width: <%= ((@last_checked_moon[:days_until_new_moon] || 0) / 14.0) * 100 %>%;"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="moon-card">
      <p style="text-align: center; color: var(--moon-text-muted);">No moon data available.</p>
    </div>
  <% end %>
</div>